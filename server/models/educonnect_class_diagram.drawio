<?xml version="1.0" ?><mxfile host="app.diagrams.net" modified="2026-04-04T14:10:00Z" agent="GPT-5.4 Pro" version="24.7.17"><diagram name="EduConnect Class Diagram" id="educonnect-class"><mxGraphModel dx="2000" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="100" value="Express API / Controller Layer" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1.5;fontStyle=1;align=left;verticalAlign=top;spacingTop=8;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="30" y="30" width="1940" height="340" as="geometry"/></mxCell><mxCell id="101" value="Sequelize Domain Model" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1.5;fontStyle=1;align=left;verticalAlign=top;spacingTop=8;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="30" y="400" width="1940" height="610" as="geometry"/></mxCell><mxCell id="102" value="Infrastructure / External Services" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1.5;fontStyle=1;align=left;verticalAlign=top;spacingTop=8;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="30" y="1040" width="1940" height="210" as="geometry"/></mxCell><mxCell id="103" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;controller&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;AuthController&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ register(fullName, email, password, role)&lt;br/&gt;+ login(email, password, role)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="70" y="100" width="260" height="120" as="geometry"/></mxCell><mxCell id="104" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;controller&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;ProfileController&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ getProfile(userId)&lt;br/&gt;+ updateProfile(userId, fullName, bio, profileImage)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="360" y="100" width="280" height="120" as="geometry"/></mxCell><mxCell id="105" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;controller&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;DashboardController&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ getStudentDashboard(userId)&lt;br/&gt;+ getInstructorDashboard(userId)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="670" y="100" width="280" height="120" as="geometry"/></mxCell><mxCell id="106" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;controller&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;CourseController&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ getAllCourses()&lt;br/&gt;+ getCourse(courseId)&lt;br/&gt;+ getInstructorCourses()&lt;br/&gt;+ createCourse(data, files)&lt;br/&gt;+ updateCourse(courseId, data, files)&lt;br/&gt;+ getCourseTopics(courseId)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="980" y="70" width="330" height="180" as="geometry"/></mxCell><mxCell id="107" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;controller&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;EnrollmentController&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ requestEnrollment(courseId)&lt;br/&gt;+ getMyEnrollment(courseId)&lt;br/&gt;+ getPendingEnrollments(courseId)&lt;br/&gt;+ approveEnrollment(enrollmentId)&lt;br/&gt;+ rejectEnrollment(enrollmentId)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1340" y="70" width="330" height="180" as="geometry"/></mxCell><mxCell id="108" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;controller&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;ProgressController&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ getProgress()&lt;br/&gt;+ updateProgress(courseId, progressPercent)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1680" y="100" width="250" height="120" as="geometry"/></mxCell><mxCell id="109" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;middleware&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;TokenMiddleware&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ validateToken(req, res, next)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="350" y="260" width="320" height="80" as="geometry"/></mxCell><mxCell id="110" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;controller&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;ChatController&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ chat(message, history, page, courseId)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="690" y="250" width="330" height="90" as="geometry"/></mxCell><mxCell id="111" value="Controllers in this diagram represent Express route modules. React frontend pages/components are functional components, so they are omitted from this class view." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1060" y="275" width="800" height="60" as="geometry"/></mxCell><mxCell id="112" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;entity&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;User&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ id: int&lt;br/&gt;+ fullName: string&lt;br/&gt;+ email: string&lt;br/&gt;+ password: string&lt;br/&gt;+ role: UserRole&lt;br/&gt;+ bio: text?&lt;br/&gt;+ profileImage: string?&lt;br/&gt;+ createdAt: datetime&lt;br/&gt;+ updatedAt: datetime&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="470" width="330" height="240" as="geometry"/></mxCell><mxCell id="113" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;enumeration&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;UserRole&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ student&lt;br/&gt;+ instructor&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="120" y="760" width="220" height="95" as="geometry"/></mxCell><mxCell id="114" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;entity&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;Course&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ id: int&lt;br/&gt;+ title: string&lt;br/&gt;+ description: text&lt;br/&gt;+ category: string?&lt;br/&gt;+ thumbnail: string?&lt;br/&gt;+ instructorId: int&lt;br/&gt;+ createdAt: datetime&lt;br/&gt;+ updatedAt: datetime&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="530" y="450" width="370" height="260" as="geometry"/></mxCell><mxCell id="115" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;entity&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;Topic&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ id: int&lt;br/&gt;+ title: string&lt;br/&gt;+ courseId: int&lt;br/&gt;+ createdAt: datetime&lt;br/&gt;+ updatedAt: datetime&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1000" y="470" width="300" height="200" as="geometry"/></mxCell><mxCell id="116" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;entity&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;Subtopic&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ id: int&lt;br/&gt;+ title: string&lt;br/&gt;+ fileUrl: string?&lt;br/&gt;+ topicId: int&lt;br/&gt;+ createdAt: datetime&lt;br/&gt;+ updatedAt: datetime&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1400" y="470" width="330" height="210" as="geometry"/></mxCell><mxCell id="117" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;association entity&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;Enrollment&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ id: int&lt;br/&gt;+ userId: int&lt;br/&gt;+ courseId: int&lt;br/&gt;+ status: EnrollmentStatus&lt;br/&gt;+ createdAt: datetime&lt;br/&gt;+ updatedAt: datetime&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="380" y="780" width="310" height="170" as="geometry"/></mxCell><mxCell id="118" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;entity&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;Progress&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ id: int&lt;br/&gt;+ userId: int&lt;br/&gt;+ courseId: int&lt;br/&gt;+ progressPercent: int (0..100)&lt;br/&gt;+ lastAccessedAt: datetime?&lt;br/&gt;+ createdAt: datetime&lt;br/&gt;+ updatedAt: datetime&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="740" y="780" width="310" height="180" as="geometry"/></mxCell><mxCell id="119" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;enumeration&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;EnrollmentStatus&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ pending&lt;br/&gt;+ approved&lt;br/&gt;+ rejected&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1450" y="770" width="250" height="95" as="geometry"/></mxCell><mxCell id="120" value="Student and Instructor are stored in User.role, not as separate subclasses." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1710" y="760" width="220" height="120" as="geometry"/></mxCell><mxCell id="121" value="The AI assistant is implemented through /api/chat, which builds context from User, Course, Topic and Subtopic data before calling Gemini." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="60" y="1070" width="500" height="120" as="geometry"/></mxCell><mxCell id="122" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;external service&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;VercelBlobStorage&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ put(file): url&lt;br/&gt;+ handleUpload(request): uploadToken&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="820" y="1080" width="360" height="110" as="geometry"/></mxCell><mxCell id="123" value="&lt;div style='text-align:center;font-weight:bold;font-size:12px;'&gt;&amp;lt;&amp;lt;external service&amp;gt;&amp;gt;&lt;br&gt;&lt;span style='font-size:16px'&gt;GeminiAPI&lt;/span&gt;&lt;/div&gt;&lt;hr/&gt;&lt;div&gt;+ generateContent(contents): reply&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="126